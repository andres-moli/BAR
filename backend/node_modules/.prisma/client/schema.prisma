generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CASHIER
  WAITER
}

enum AccountType {
  CASH
  BANK
  DIGITAL_WALLET
  OTHER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum OrderStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CollectionStatus {
  PENDING
  PARTIALLY_PAID
  PAID
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([name])
  @@index([isActive])
  @@map("categories")
}

model Account {
  id        String      @id @default(uuid())
  name      String      @unique
  type      AccountType @default(CASH)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  paymentMethods PaymentMethod[]
  cashMovements  CashMovement[]

  @@index([name])
  @@index([type])
  @@map("accounts")
}

model PaymentMethod {
  id        String   @id @default(uuid())
  name      String   @unique
  accountId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account            Account             @relation(fields: [accountId], references: [id])
  payments           Payment[]
  collectionPayments CollectionPayment[]

  @@index([name])
  @@index([accountId])
  @@map("payment_methods")
}

model CashRegister {
  id            String             @id @default(uuid())
  date          DateTime           @default(now())
  initialAmount Decimal            @default(0)
  finalAmount   Decimal?
  status        CashRegisterStatus @default(OPEN)
  openedBy      String
  closedBy      String?
  openedAt      DateTime           @default(now())
  closedAt      DateTime?
  notes         String?

  movements CashMovement[]

  @@index([status])
  @@index([date])
  @@index([openedBy])
  @@map("cash_registers")
}

model CashMovement {
  id             String   @id @default(uuid())
  cashRegisterId String
  accountId      String
  amount         Decimal  @default(0)
  type           String   @default("INCOME")
  description    String?
  reference      String?
  paymentId      String?
  createdAt      DateTime @default(now())

  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([cashRegisterId])
  @@index([accountId])
  @@index([createdAt])
  @@map("cash_movements")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(WAITER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  payments  Payment[]
  movements Movement[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Table {
  id        String      @id @default(uuid())
  number    Int         @unique
  status    TableStatus @default(AVAILABLE)
  capacity  Int         @default(4)
  location  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  orders Order[]

  @@index([number])
  @@index([status])
  @@map("tables")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal  @default(0)
  cost        Decimal? @default(0)
  categoryId  String
  isActive    Boolean  @default(true)
  stock       Int      @default(0)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  movements  Movement[]

  @@index([categoryId])
  @@index([name])
  @@index([isActive])
  @@map("products")
}

model Order {
  id        String      @id @default(uuid())
  status    OrderStatus @default(OPEN)
  notes     String?
  subtotal  Decimal     @default(0)
  tax       Decimal     @default(0)
  total     Decimal     @default(0)
  discount  Decimal     @default(0)
  tableId   String?
  userId    String
  clientId  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  closedAt  DateTime?

  table    Table?      @relation(fields: [tableId], references: [id])
  user     User        @relation(fields: [userId], references: [id])
  client   Client?     @relation(fields: [clientId], references: [id])
  items    OrderItem[]
  payments Payment[]
  invoice  Invoice?

  @@index([status])
  @@index([tableId])
  @@index([userId])
  @@index([clientId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  quantity  Int      @default(1)
  unitPrice Decimal  @default(0)
  subtotal  Decimal  @default(0)
  notes     String?
  orderId   String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id              String   @id @default(uuid())
  amount          Decimal  @default(0)
  paymentMethodId String
  reference       String?
  orderId         String
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  order         Order         @relation(fields: [orderId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@index([paymentMethodId])
  @@index([orderId])
  @@index([createdAt])
  @@map("payments")
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  subtotal      Decimal  @default(0)
  tax           Decimal  @default(0)
  total         Decimal  @default(0)
  discount      Decimal  @default(0)
  nit           String?
  name          String?
  email         String?
  orderId       String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([invoiceNumber])
  @@index([orderId])
  @@index([createdAt])
  @@map("invoices")
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  document  String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders             Order[]
  collectionAccounts CollectionAccount[]

  @@index([email])
  @@index([document])
  @@index([phone])
  @@map("clients")
}

model CollectionAccount {
  id          String           @id @default(uuid())
  totalAmount Decimal          @default(0)
  paidAmount  Decimal          @default(0)
  status      CollectionStatus @default(PENDING)
  notes       String?
  clientId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  dueDate     DateTime?

  client   Client              @relation(fields: [clientId], references: [id])
  payments CollectionPayment[]

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("collection_accounts")
}

model CollectionPayment {
  id                  String   @id @default(uuid())
  amount              Decimal  @default(0)
  paymentMethodId     String
  reference           String?
  collectionAccountId String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  paymentMethod     PaymentMethod     @relation(fields: [paymentMethodId], references: [id])
  collectionAccount CollectionAccount @relation(fields: [collectionAccountId], references: [id], onDelete: Cascade)

  @@index([paymentMethodId])
  @@index([collectionAccountId])
  @@map("collection_payments")
}

model Movement {
  id          String   @id @default(uuid())
  type        String
  quantity    Int
  description String?
  productId   String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
  @@map("movements")
}
